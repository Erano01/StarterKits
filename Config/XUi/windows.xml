                    </grid>
                </panel>

                <panel name="overview_panel" pos="514,-55" width="510" height="745" depth="1" backgroundcolor="[black]">
                    <!-- TITLE FOR OVERVİEW -->
                    <label depth="2" pos="0,-12" width="510" font_size="28" color="[white]" justify="center" text="Selection Overview" />

                    <rect name="overviewFrame" depth="2" pos="35,-55" width="440" height="655" backgroundcolor="22,22,22,255">
                        <sprite depth="3" pos="0,0" width="440" height="655" sprite="menu_empty3px" color="[mediumGrey]" type="sliced" fillcenter="false" />

                        <label name="lblSelectedKitName" depth="4" pos="0,-18" width="440" font_size="26" color="[white]" justify="center" text="No Kit Selected" />
