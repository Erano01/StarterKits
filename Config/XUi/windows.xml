<configs>
	<append xpath="/windows">
<!--
1. 
window width = 1024, window height = 800, window pos="-512,400", anchor="CenterCenter"
grid width = 390, grid height = 270
row count = 2, column count = 2

2.
(window width - grid width) / row count = horizontal spacing  (x-axis)      
header - (header + spacing) = vertical spacing (y-axis) 

3.
pos değeri, elemanın anchor/pivot referans noktasına göre offset’idir.
anchor -> mevcut element'i nereye sabitleyeceğin. (css position: absolute; gibi düşünebilirsin)
ancak bu tam olarak ortalamaz sadece başlangıç noktası olarak alır.
Tam ortalamak için mevcut elementin width'inin yarısı kadar negatif offset vermen gerekir.
Misal window=starterKitWindow için:
anchor="CenterCenter" ise tam ortaya almak istiyorsan ve width 1024 ise -512 verirsin pos'un x değerine.

4.
pivot -> pivot, child elementin kendi içindeki referans noktasını belirler.
anchor -> parent'a göre konumlandırma
-->
		<window name="starterKitWindow"
			controller="StarterKits.XUiC_KitSelectionMenu, StarterKits"
			is_modal="true"
			allow_escape="true"
			anchor="CenterCenter"
			pos="-512,400"
			width="1024" 
			height="800"
			cursor_area="true">

			<panel name="rootPanel" width="1024" height="800">
                <!-- HEADER -->
                <!-- panel height - label font_size = label pos y value  -->
				<panel name="header" pos="0,0" width="1024" height="50" depth="1" backgroundcolor="[black]">
					<label depth="2" pos="0,-12" width="1024" font_size="28" color="[white]" justify="center" text="Starter Kits" />
				</panel>

                <panel name="selection_panel" pos="0,-55" width="509" height="745" depth="1" backgroundcolor="[white]">
                    <!-- SELECTION TITLE -->
                    <label depth="2" pos="0,-12" width="509" font_size="28" color="[black]" justify="center" text="Choose one of these: " />
                    
                    <!-- SELECTION GRID -->
                    <grid name="kitOptions"
                        pos="60,-65"
                        width="390"
                        height="525"
                        rows="7"
                        cols="2"
                        cell_width="190"
                        cell_height="75"
                        arrangement="horizontal"
                        repeat_content="false">

                        <rect name="Scavenger" depth="1" backgroundcolor="[darkGrey]">
                            <simplebutton name="btnScavenger" style="press, hover" width="190" height="75" pos="0,0" caption="Scavenger" font_size="20" />
                            <rect name="selScavenger" depth="2" pos="0,0" width="190" height="75" visible="false" gamepad_selectable="false">
                                <sprite depth="3" pos="0,0" width="190" height="75" sprite="menu_empty" color="222,206,163,48" type="sliced" />
                                <sprite depth="4" pos="0,0" width="190" height="75" sprite="menu_empty3px" color="[selectedColor]" type="sliced" fillcenter="false" />
                            </rect>
                        </rect>

                        <rect name="Huntsman" depth="1" backgroundcolor="[darkGrey]">
                            <simplebutton name="btnHuntsman" style="press, hover" width="190" height="75" pos="0,0" caption="Huntsman" font_size="20" />
