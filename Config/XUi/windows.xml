<configs>
	<append xpath="/windows">
		<window name="starterKitWindow"
			controller="StarterKits.XUiC_KitSelectionMenu, StarterKits"
			is_modal="true"
			allow_escape="true"
			anchor="CenterCenter"
			pos="-220,180"
			width="440"
			height="360"
			cursor_area="true">

			<panel name="rootPanel">
				<panel name="header" pos="0,0" width="440" height="45" depth="1" backgroundcolor="[black]">
					<label depth="2" pos="10,-6" width="420" font_size="28" color="[white]" justify="center" text="Starter Kits" />
				</panel>

				<grid name="kitOptions"
					pos="25,-65"
					width="390"
					height="270"
					rows="2"
					cols="2"
					cell_width="190"
					cell_height="130"
					arrangement="horizontal"
					repeat_content="false">

					<rect name="Builder" depth="1" backgroundcolor="[darkGrey]">
						<simplebutton name="btnBuilder" style="press, hover" width="190" height="130" pos="0,0" caption="Builder" font_size="26" />
					</rect>

					<rect name="Archer" depth="1" backgroundcolor="[darkGrey]">
						<simplebutton name="btnArcher" style="press, hover" width="190" height="130" pos="0,0" caption="Archer" font_size="26" />
					</rect>

					<rect name="Tyson" depth="1" backgroundcolor="[darkGrey]">
						<simplebutton name="btnTyson" style="press, hover" width="190" height="130" pos="0,0" caption="Tyson" font_size="26" />
					</rect>

					<rect name="Spearman" depth="1" backgroundcolor="[darkGrey]">
						<simplebutton name="btnSpearman" style="press, hover" width="190" height="130" pos="0,0" caption="Spearman" font_size="26" />
					</rect>

				</grid>
			</panel>
		</window>
	</append>

	<!-- ESC menusune starter kit butonu ekle -->
	<append xpath="//window[@name='ingameMenu']//grid[@name='buttons']">
		<simplebutton name="btnStarterKit" depth="3" width="250" height="46"
			caption="Choose Your Kit" font_size="40" />
	</append>
</configs>