<configs>
	<append xpath="/windows">
<!--
1. 
window width = 440, window height = 360, window pos="-220,180", anchor="CenterCenter"
grid width = 390, grid height = 270
row count = 2, column count = 2


2.
(window width - grid width) / row count = horizontal spacing  (x-axis)      
header - (header + spacing) = vertical spacing (y-axis) 

3.
pos değeri, elemanın anchor/pivot referans noktasına göre offset’idir.
pos değerini belirlerken anchor'dan sonra önemsemen gereken 2 değer width ve height'tir.
anchor="CenterCenter" ise tam ortaya almak istiyorsan ve width 1024 ise -512 verirsin pos'un x değerine.

4.
panel elementleri ile pixel perfect design yapılamadığı için. padding 5 px ayarladık.
pixel perfect'dan kastımız elemanların birbirine tam yapışık olması.
-->
		<window name="starterKitWindow"
			controller="StarterKits.XUiC_KitSelectionMenu, StarterKits"
			is_modal="true"
			allow_escape="true"
			anchor="CenterCenter"
			pos="-512,400"
			width="1024" 
			height="800"
			cursor_area="true">

			<panel name="rootPanel" width="1024" height="800">
                <!-- HEADER -->
                <!-- panel height - label font_size = label pos y value  -->
				<panel name="header" pos="0,0" width="1024" height="50" depth="1" backgroundcolor="[black]">
					<label depth="2" pos="0,-12" width="1024" font_size="28" color="[white]" justify="center" text="Starter Kits" />
				</panel>

                <panel name="selection_panel" pos="0,-55" width="509" height="745" depth="1" backgroundcolor="[white]">
                    <!-- SELECTION TITLE -->
                    <label depth="2" pos="0,-12" width="509" font_size="28" color="[black]" justify="center" text="Choose one of these: " />
                    
                    <!-- SELECTION GRID -->
                    <grid name="kitOptions"
                        pos="35,-100"
                        width="390"
                        height="270"
                        rows="2"
                        cols="2"
                        cell_width="190"
                        cell_height="130"
                        arrangement="horizontal"
                        repeat_content="false">

                        <rect name="Builder" depth="1" backgroundcolor="[darkGrey]">
                            <simplebutton name="btnBuilder" style="press, hover" width="190" height="130" pos="0,0" caption="Builder" font_size="26" />
                        </rect>

                        <rect name="Archer" depth="1" backgroundcolor="[darkGrey]">
                            <simplebutton name="btnArcher" style="press, hover" width="190" height="130" pos="0,0" caption="Archer" font_size="26" />
                        </rect>

                        <rect name="Tyson" depth="1" backgroundcolor="[darkGrey]">
                            <simplebutton name="btnTyson" style="press, hover" width="190" height="130" pos="0,0" caption="Tyson" font_size="26" />
                        </rect>

                        <rect name="Spearman" depth="1" backgroundcolor="[darkGrey]">
                            <simplebutton name="btnSpearman" style="press, hover" width="190" height="130" pos="0,0" caption="Spearman" font_size="26" />
                        </rect>

                    </grid>
                </panel>

                <panel name="overview_panel" pos="514,-55" width="510" height="745" depth="1" backgroundcolor="[black]">
                    <!-- TITLE FOR OVERVİEW -->
                    <label depth="2" pos="0,-12" width="510" font_size="28" color="[white]" justify="center" text="Selection Overview" />
                </panel>
			</panel>
		</window>
	</append>

	<!-- ESC menusune starter kit butonu ekle -->
	<append xpath="//window[@name='ingameMenu']//grid[@name='buttons']">
		<simplebutton name="btnStarterKit" depth="3" width="250" height="46"
			caption="Choose Your Kit" font_size="40" />
	</append>
</configs>